#--------------------------------------------------------------------
# LINKEDIN OAuth (required for LinkedIn profile import)
# 1. Go to https://www.linkedin.com/developers/apps/new
# 2. Create an app, add "Sign In with LinkedIn using OpenID Connect" product
# 3. Under "Auth" tab, set Authorized Redirect URL to:
#    https://persomy.com/linkedin/callback
# 4. Copy your Client ID and Client Secret below (in your .env file)
#--------------------------------------------------------------------

# LINKEDIN_CLIENT_ID     = your_client_id_here
# LINKEDIN_CLIENT_SECRET = your_client_secret_here

#--------------------------------------------------------------------
# CV PARSING SERVICE (Python microservice integration)
# For enhanced CV parsing with AI (Ollama)
#--------------------------------------------------------------------

# Enable CV Parsing integration
# CV_PARSING_ENABLED = true

# Base URL of Python CV Parsing microservice (must be 127.0.0.1:8001 on prod)
# CV_PARSING_BASE_URL = http://127.0.0.1:8001

# API Key for authentication — must match API_KEY in cv-parsing-service/.env.production
# REQUIRED: set this in your .env on the server or the service will return HTTP 401
# CV_PARSING_API_KEY = your-secret-api-key-here

# Request timeouts (seconds)
# CV_PARSING_TIMEOUT = 60
# CV_PARSING_CONNECT_TIMEOUT = 10

# Max file size for upload (MB)
# CV_PARSING_MAX_SIZE_MB = 10
