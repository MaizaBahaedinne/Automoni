# Production Environment Configuration
# IMPORTANT: Update these values for your production environment

# API Settings
API_HOST=0.0.0.0
API_PORT=8001
API_KEY=CHANGE_THIS_TO_A_STRONG_SECRET_KEY_IN_PROD

# Environment
ENV=production

# Ollama (point to production instance)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT=300

# File Upload Limits
UPLOAD_DIR=/var/uploads/cv-parsing
MAX_FILE_SIZE_MB=20

# Logging
LOG_LEVEL=WARNING
LOG_FILE=/var/log/cv-parsing/cv_parsing.log

# CORS Origins (restrict to your CI4 domain)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
